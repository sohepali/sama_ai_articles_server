# Required: PostgreSQL connection string from Supabase/Render/Postgres.
# Example:
# DATABASE_URL=postgresql://postgres.projectref:password@aws-1-region.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Required for admin endpoints used by n8n/admin dashboard.
ADMIN_TOKEN=change-this-long-random-admin-token

# Optional but recommended for the Windows app sync endpoint.
APP_SYNC_TOKEN=change-this-long-random-app-sync-token

# Article extraction settings.
NEWS_MIN_FULL_CHARS=600
NEWS_MAX_ARTICLES_PER_SOURCE=25
NEWS_MAX_DOCUMENTS_PER_ARTICLE=3
NEWS_MAX_DOCUMENT_BYTES=20971520
NEWS_REQUEST_TIMEOUT=25
NEWS_APPROVE_PARTIAL=false

# Optional CORS setting.
CORS_ORIGINS=*

